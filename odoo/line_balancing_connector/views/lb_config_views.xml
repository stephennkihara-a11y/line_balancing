<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lb_config_form" model="ir.ui.view">
        <field name="name">lb.config.form</field>
        <field name="model">lb.config</field>
        <field name="arch" type="xml">
            <form string="Line Balancing — Configuration">
                <sheet>
                    <group>
                        <field name="enabled"/>
                        <field name="base_url"/>
                        <field name="username"/>
                        <field name="password" password="True"/>
                        <field name="last_sync" readonly="1"/>
                    </group>
                    <group string="What to sync">
                        <field name="sync_styles"/>
                        <field name="sync_operators"/>
                        <field name="sync_machines"/>
                        <field name="sync_balance_runs"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_lb_config_list" model="ir.ui.view">
        <field name="name">lb.config.list</field>
        <field name="model">lb.config</field>
        <field name="arch" type="xml">
            <list string="Line Balancing — Configurations">
                <field name="base_url"/>
                <field name="username"/>
                <field name="last_sync"/>
                <field name="enabled"/>
            </list>
        </field>
    </record>

    <record id="action_lb_config" model="ir.actions.act_window">
        <field name="name">Line Balancing — Settings</field>
        <field name="res_model">lb.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lb_root"
              name="Line Balancing"
              parent="mrp.menu_mrp_root"
              sequence="80"/>
    <menuitem id="menu_lb_config"
              name="Settings"
              parent="menu_lb_root"
              action="action_lb_config"
              sequence="100"/>
</odoo>
